<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:andorid="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">


    <ImageView
        android:id="@+id/ivImagen"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop" />

    <LinearLayout
        android:id="@+id/llContenido"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        andorid:paddingEnd="12dp">

        <TextView
            android:id="@+id/tvTitleLanzamiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="titulo del lanzamiento"
            android:textAppearance="?attr/textAppearanceSubtitle1" />

        <TextView
            android:id="@+id/tvNombreLanzamiento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre del lanzamiento"
            android:textAppearance="?attr/textAppearanceBody2" />

        <TextView
            android:id="@+id/tvContnet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="contenido del lanzamiento"
            android:textAppearance="?attr/textAppearanceBody2"
            />

    </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>